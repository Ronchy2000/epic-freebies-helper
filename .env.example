# Epic account
# Required.
EPIC_EMAIL=
EPIC_PASSWORD=

# Provider
# Required.
# Supported values: glm, openai, gemini
LLM_PROVIDER=glm

# GLM
# Required when LLM_PROVIDER=glm.
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v

# OpenAI / GPT
# Required when LLM_PROVIDER=openai.
# OPENAI_MODEL must support image input.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Gemini / AiHubMix
# Required when LLM_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://aihubmix.com
GEMINI_MODEL=gemini-2.5-pro

# Advanced model overrides
# Optional. Leave empty unless different models are required for different captcha tasks.
CHALLENGE_CLASSIFIER_MODEL=
IMAGE_CLASSIFIER_MODEL=
SPATIAL_POINT_REASONER_MODEL=
SPATIAL_PATH_REASONER_MODEL=

# Runtime
ENABLE_APSCHEDULER=false
